def _store_path_name(path: str) -> str:
    """Extract name from a store path (strip hash prefix).

    e.g. '/nix/store/abc...-hello-2.12.1.drv' -> 'hello-2.12.1.drv'
    """
    basename = path.rsplit("/", 1)[-1]
    if len(basename) > 33 and basename[32] == "-":
        return basename[33:]
    return basename

@dataclass
class DrvInfo:
    """Parsed derivation metadata, populated from the .drv file on disk."""
    path: str
    name: str
    builder: str
    env: dict[str, str]
    outputs: dict[str, dict]
    input_drvs: dict[str, dict]   # drv path -> {"outputs": [...]}
    input_srcs: list[str]         # plain store paths
    structured_attrs: dict        # pre-parsed __json (if present)

    def is_fod(self) -> bool:
        """A fixed-output derivation has a content hash on at least one output."""
        return any(o.get("hash") for o in self.outputs.values())

    def is_package(self) -> bool:
        """A 'real package' has a non-empty version in its environment."""
        return bool(self.env.get("version", ""))

    def store_path_name(self) -> str:
        """The name part of the .drv store path (hash and .drv stripped)."""
        return _store_path_name(self.path).removesuffix(".drv")

# ATerm parsing for .drv files. The format is stable and documented as part of
# Nix's on-disk store format: Derive(outputs, inputDrvs, inputSrcs, system,
# builder, args, env). Parsing directly avoids `nix derivation show`, whose
# JSON schema has churned across Nix versions.

_ATERM_ESCAPES = {ord("n"): b"\n", ord("r"): b"\r", ord("t"): b"\t"}

# ATerm values: strings, lists of values, tuples of values, or (constructor_name, args_tuple).
ATermValue = Union[str, list, tuple]

def _aterm_parse_string(data: bytes, i: int) -> tuple[str, int]:
    assert data[i:i+1] == b'"'
    i += 1
    out = bytearray()
    while True:
        c = data[i]
        if c == 0x22:  # "
            return out.decode("utf-8", errors="replace"), i + 1
        if c == 0x5C:  # backslash
            nxt = data[i + 1]
            out += _ATERM_ESCAPES.get(nxt, bytes([nxt]))
            i += 2
        else:
            out.append(c)
            i += 1

def _aterm_parse(data: bytes, i: int) -> tuple[ATermValue, int]:
    c = data[i:i+1]
    if c == b'"':
        return _aterm_parse_string(data, i)
    if c == b"[":
        items: list = []
        i += 1
        if data[i:i+1] == b"]":
            return items, i + 1
        while True:
            v, i = _aterm_parse(data, i)
            items.append(v)
            if data[i:i+1] == b",":
                i += 1
                continue
            assert data[i:i+1] == b"]", f"expected ']' at {i}, got {data[i:i+1]!r}"
            return items, i + 1
    if c == b"(":
        items = []
        i += 1
        if data[i:i+1] == b")":
            return tuple(items), i + 1
        while True:
            v, i = _aterm_parse(data, i)
            items.append(v)
            if data[i:i+1] == b",":
                i += 1
                continue
            assert data[i:i+1] == b")", f"expected ')' at {i}"
            return tuple(items), i + 1
    # Constructor: Name(args)
    j = i
    while data[j:j+1].isalpha() or data[j:j+1].isdigit() or data[j:j+1] == b"_":
        j += 1
    name = data[i:j].decode("ascii")
    assert data[j:j+1] == b"(", f"expected '(' after constructor {name!r} at {j}"
    args, j = _aterm_parse(data, j)  # parses the tuple including parens
    return (name, args), j

def _parse_drv_file(path: str) -> DrvInfo:
    """Parse a .drv file (ATerm) into a DrvInfo.

    The dicts returned (`outputs`, `input_drvs`) mirror the shape previously
    produced from `nix derivation show` JSON, so downstream consumers
    (is_fod, fod_name, collect_sources, etc.) work unchanged.
    """
    with open(path, "rb") as f:
        data = f.read()
    tree, end = _aterm_parse(data, 0)
    if not (isinstance(tree, tuple) and len(tree) == 2 and tree[0] == "Derive"):
        raise RuntimeError(
            f"Unexpected top-level constructor in {path}: {tree[0] if isinstance(tree, tuple) else type(tree).__name__}. "
            f"nvd only supports standard Derive(...) drv files.")
    outputs_list, input_drvs_list, input_srcs, system, builder, args, env_list = tree[1]

    outputs = {
        name: {"path": out_path, "hashAlgo": hash_algo, "hash": hash_value}
        for (name, out_path, hash_algo, hash_value) in outputs_list
    }
    input_drvs = {
        drv_path: {"outputs": list(out_names)}
        for (drv_path, out_names) in input_drvs_list
    }
    env: dict[str, str] = {k: v for (k, v) in env_list}
    structured_attrs: dict = {}
    if env.get("__structuredAttrs") == "1":
        raw_json = env.get("__json", "")
        if raw_json:
            try:
                structured_attrs = json.loads(raw_json)
            except json.JSONDecodeError:
                structured_attrs = {}

    return DrvInfo(
        path=path,
        name=env.get("name", ""),
        builder=builder,
        env=env,
        outputs=outputs,
        input_drvs=input_drvs,
        input_srcs=list(input_srcs),
        structured_attrs=structured_attrs,
    )

def load_drv_graph(drv_paths: Union[str, list[str]]) -> dict[str, DrvInfo]:
    """Load the full transitive .drv graph by reading .drv files from disk.

    Accepts a single drv path or a list of paths. Returns a dict mapping
    drv paths to DrvInfo objects.
    """
    if isinstance(drv_paths, str):
        drv_paths = [drv_paths]
    visited: dict[str, DrvInfo] = {}
    queue: deque[str] = deque(drv_paths)
    while queue:
        p = queue.popleft()
        if p in visited:
            continue
        try:
            drv = _parse_drv_file(p)
        except FileNotFoundError:
            raise RuntimeError(
                f"Derivation not found on disk: {p}. "
                f"It may have been garbage-collected; "
                f"try `nix-store --realise <root>` first.")
        visited[p] = drv
        queue.extend(drv.input_drvs.keys())
    return visited

# FOD naming

GENERIC_NAMES = frozenset(["source", "download", "patch"])

def _repo_name_from_url(url: str) -> Optional[str]:
    """Extract a repo/project name from a URL. Returns None if not possible."""
    parts = url.split("://", 1)
    if len(parts) < 2:
        return None
    path = parts[1].split("?", 1)[0]
    segments = [s for s in path.split("/") if s]
    # GitHub/GitLab: host/owner/repo/...
    if len(segments) >= 3 and ("github" in segments[0] or "gitlab" in segments[0]):
        return segments[2]
    return None

def _fod_name_from_structured_attrs(sa: dict) -> Optional[str]:
    """Try to extract a descriptive name from structuredAttrs."""
    # fetchFromGitHub / fetchFromGitLab
    repo = sa.get("repo")
    if isinstance(repo, str) and repo not in GENERIC_NAMES:
        return repo
    # fetchgit
    url = sa.get("url")
    if isinstance(url, str) and sa.get("rev"):
        name = _repo_name_from_url(url)
        if name and name not in GENERIC_NAMES:
            return name
    # fetchzip
    urls = sa.get("urls")
    if isinstance(urls, list) and urls:
        name = _repo_name_from_url(urls[0])
        if name and name not in GENERIC_NAMES:
            return name
    return None

def fod_name(drv: DrvInfo) -> str:
    """Extract a descriptive name for a FOD.

    Naming strategies tried in order, skipping generic results:
    1. builtin:fetchurl -> env name (always descriptive)
    2. structuredAttrs -> repo/url extraction
    3. env name (if not generic)
    4. Store path name (universal fallback)
    """
    # builtin:fetchurl — always has a descriptive env name
    if drv.builder == "builtin:fetchurl":
        name = drv.env.get("name", "")
        return name if name else drv.store_path_name()

    # Try structuredAttrs (fetchFromGitHub, fetchgit, fetchzip)
    if drv.structured_attrs:
        name = _fod_name_from_structured_attrs(drv.structured_attrs)
        if name:
            return name

    # Plain fetchurl — env name if not generic
    env_name = drv.env.get("name", "")
    if env_name and env_name not in GENERIC_NAMES:
        return env_name

    # Universal fallback
    return drv.store_path_name()

# Graph walk with parent tracking

def walk_drv_graph_with_parents(
    drvs: dict[str, DrvInfo],
    root: str,
) -> tuple[set[str], dict[str, str]]:
    """BFS walk of the .drv graph. Returns (visited_set, parent_map).

    parent_map maps each drv path and input_source path to its nearest
    'package' ancestor name. A package is a non-FOD derivation with a
    version in its environment.
    """
    visited: set[str] = set()
    parent_map: dict[str, str] = {}
    root_drv = drvs.get(root)
    root_name = root_drv.store_path_name() if root_drv else root
    queue: deque[tuple[str, str]] = deque([(root, root_name)])

    while queue:
        drv_path, parent_name = queue.popleft()
        if drv_path in visited:
            continue
        visited.add(drv_path)

        drv = drvs.get(drv_path)
        if drv is None:
            continue

        # Only non-FOD packages with a version become parents
        if not drv.is_fod() and drv.is_package():
            propagated = drv.store_path_name()
        else:
            propagated = parent_name

        parent_map.setdefault(drv_path, parent_name)

        for input_path in drv.input_drvs:
            if input_path not in visited:
                parent_map.setdefault(input_path, propagated)
                queue.append((input_path, propagated))

        for input_src in drv.input_srcs:
            parent_map.setdefault(input_src, propagated)

    return visited, parent_map

# Source collection

@dataclass
class SourceEntry:
    path: str
    name: str
    kind: str              # "fod" or "input_source"
    parent: str
    parent_pname: str      # version-free parent name
    parent_version: str    # parent version (may be empty)
    output_path: str       # resolved output store path (for FODs)
    fod_hash_algo: str = ""  # e.g. "sha256" for FODs, "" for input_sources
    fod_hash: str = ""       # declared FOD hash, "" for input_sources

def collect_sources(
    drvs: dict[str, DrvInfo],
    unique_drv_paths: set[str],
    parent_map: dict[str, str],
    root_name: str,
    exclude_fod_outputs: Optional[set[str]] = None,
    exclude_input_srcs: Optional[set[str]] = None,
) -> list[SourceEntry]:
    """Collect FOD sources and input_sources from unique derivations.

    Content-based exclusion filters apply on top of the drv-path-based
    exclusion encoded in unique_drv_paths: a FOD output path or input_src
    that appears in the exclude graph is dropped even if its referring
    drv is "new" (the outer drv churns on rebase while the content doesn't).
    """
    excl_fod = exclude_fod_outputs or set()
    excl_is = exclude_input_srcs or set()
    sources: list[SourceEntry] = []
    seen_outputs: set[str] = set()
    seen_input_srcs: set[str] = set()

    for drv_path in unique_drv_paths:
        drv = drvs.get(drv_path)
        if drv is None:
            continue

        parent = parent_map.get(drv_path, "")
        ppname, pversion = parse_name_version(parent)

        # Collect FODs
        if drv.is_fod():
            name = fod_name(drv)
            out = drv.outputs.get("out", {})
            output_path = out.get("path", "")
            if (output_path
                    and output_path not in seen_outputs
                    and output_path not in excl_fod):
                seen_outputs.add(output_path)
                sources.append(SourceEntry(
                    path=drv_path, name=name, kind="fod", parent=parent,
                    parent_pname=ppname, parent_version=pversion or "",
                    output_path=output_path,
                    fod_hash_algo=out.get("hashAlgo", ""),
                    fod_hash=out.get("hash", "")))

        # Collect input_sources
        for src_path in drv.input_srcs:
            if src_path in seen_input_srcs or src_path in excl_is:
                continue
            seen_input_srcs.add(src_path)
            src_name = _store_path_name(src_path)
            src_parent = parent_map.get(src_path, parent)
            sp_pname, sp_version = parse_name_version(src_parent)
            sources.append(SourceEntry(
                path=src_path, name=src_name, kind="input_source",
                parent=src_parent, parent_pname=sp_pname,
                parent_version=sp_version or "", output_path=src_path))

    # Sort by parent, kind, name, then store path name for stability
    sources.sort(key=lambda s: (s.parent, s.kind, s.name, _store_path_name(s.path)))

    # Disambiguate entries sharing the same parent/name. Input-source
    # filename collisions (e.g. several patches named the same) are common
    # and cosmetic — silently suffix them. FOD collisions usually mean
    # fod_name fell back to a generic token, which is worth surfacing.
    seen_keys: dict[tuple[str, str], int] = {}
    for source in sources:
        key = (source.parent, source.name)
        count = seen_keys.get(key, 0)
        if count > 0:
            if source.parent != root_name and source.kind == "fod":
                print(
                    f"WARNING: {source.parent}/{source.name} has duplicate FODs "
                    f"(#{count}) path: {source.path}",
                    file=sys.stderr,
                )
            source.name = f"{source.name}.{count}"
        seen_keys[key] = count + 1

    return sources

def _normalize_input_path(root: str) -> str:
    """Follow ./result-style symlinks; pass bare store names through.

    Unconditional Path.resolve() would rewrite a bare store-path basename
    (e.g. 'xxx-hello.drv') as a cwd-relative absolute path, which is wrong.
    Only resolve when the input refers to something on the filesystem.
    """
    # Strip Nix's output selector (e.g. 'foo.drv!bin' from nix-instantiate
    # on multi-output drvs). Guarded by '.drv' so an unrelated '!' passes through.
    if "!" in root:
        head, _, _ = root.partition("!")
        if head.endswith(".drv"):
            root = head
    p = Path(root)
    if p.exists() or p.is_symlink():
        return str(p.resolve())
    return root

def _resolve_drv_path(path: str) -> str:
    """Resolve a store path to its .drv path if needed."""
    if path.endswith(".drv"):
        return path
    result = subprocess.run(
        [make_nix_bin_path("nix-store"), "--query", "--deriver", path],
        stdout=PIPE, text=True, check=True,
    )
    drv_path = result.stdout.strip()
    if not drv_path or drv_path == "unknown-deriver" or not Path(drv_path).exists():
        raise RuntimeError(
            f"No usable .drv registered for {path}. "
            f"The path may have been substituted from a binary cache without "
            f"its .drv, or built against a drv that's since been GC'd. "
            f"Try re-instantiating with `nix-instantiate` or building with "
            f"`nix-build` to get a live .drv.")
    print(f"Resolved {path} to {drv_path}", file=sys.stderr)
    return drv_path

def compute_sources(drv_path: str, exclude_drvs: list[str]) -> list[SourceEntry]:
    """Full pipeline: load graph, walk, exclude, collect sources."""
    drv_path = _resolve_drv_path(_normalize_input_path(drv_path))
    print(f"Loading target graph: {drv_path}", file=sys.stderr)
    drvs = load_drv_graph(drv_path)
    print(f"  {len(drvs)} derivations", file=sys.stderr)

    visited, parent_map = walk_drv_graph_with_parents(drvs, drv_path)

    # Build exclusion sets. Drv-path exclusion alone produces false-positive
    # "new" sources: the outer drv gets a new hash on rebase but its
    # content-addressed FOD outputs and input_src store paths don't.
    exclude_set: set[str] = set()
    exclude_fod_outputs: set[str] = set()
    exclude_input_srcs: set[str] = set()
    if exclude_drvs:
        resolved_excludes = [_resolve_drv_path(_normalize_input_path(e)) for e in exclude_drvs]
        for exc in resolved_excludes:
            print(f"Loading exclude graph: {exc}", file=sys.stderr)
        exc_drvs = load_drv_graph(resolved_excludes)
        print(f"  {len(exc_drvs)} derivations total", file=sys.stderr)
        exclude_set = set(exc_drvs.keys())
        for exc_drv in exc_drvs.values():
            if exc_drv.is_fod():
                for out in exc_drv.outputs.values():
                    out_path = out.get("path", "")
                    if out_path:
                        exclude_fod_outputs.add(out_path)
            exclude_input_srcs.update(exc_drv.input_srcs)

    unique = visited - exclude_set
    print(f"{len(unique)} unique derivations after exclusion", file=sys.stderr)

    root_name = drvs[drv_path].store_path_name() if drv_path in drvs else drv_path
    sources = collect_sources(
        drvs, unique, parent_map, root_name,
        exclude_fod_outputs=exclude_fod_outputs,
        exclude_input_srcs=exclude_input_srcs,
    )

    fod_count = sum(1 for s in sources if s.kind == "fod")
    is_count = sum(1 for s in sources if s.kind == "input_source")
    print(f"{len(sources)} sources ({fod_count} FODs, {is_count} input_sources)", file=sys.stderr)

    return sources

# Sources subcommands

def run_sources_list(root: str, exclude: list[str], output_format: str, **_kwargs) -> None:
    """List sources for a single derivation."""
    sources = compute_sources(root, exclude or [])

    if output_format == "json":
        entries = [{
            "path": s.path,
            "name": s.name,
            "kind": s.kind,
            "parent": s.parent,
            "output_path": s.output_path,
            "fod_hash_algo": s.fod_hash_algo or None,
            "fod_hash": s.fod_hash or None,
        } for s in sources]
        print(json.dumps(entries, indent=2))
    else:
        # Tree output grouped by parent
        current_parent = None
        for s in sources:
            if s.parent != current_parent:
                current_parent = s.parent
                print(f"\n{sgr(SGR_BOLD)}{current_parent}{sgr(SGR_RESET)}")
            kind_color = SGR_FG + SGR_CYAN if s.kind == "fod" else SGR_FG + SGR_YELLOW
            print(f"  {sgr(kind_color)}{s.kind:14s}{sgr(SGR_RESET)} {s.name}")

def _sources_to_package_set(sources: list[SourceEntry]) -> PackageSet:
    """Build a PackageSet from source entries, using parent names as packages.

    Each unique parent name becomes a Package with pname and version
    extracted from the pre-computed parent_pname/parent_version fields.
    """
    seen_parents: dict[str, SourceEntry] = {}
    for s in sources:
        if s.parent not in seen_parents:
            seen_parents[s.parent] = s

    packages: list[Package] = []
    store_paths: list[str] = []
    for parent, example_source in seen_parents.items():
        packages.append(Package(
            pname=example_source.parent_pname,
            version=Version(example_source.parent_version),
            store_path=StorePath(example_source.path),
        ))
        store_paths.append(example_source.path)

    return PackageSet(packages, store_paths)

def run_sources_diff(
    root1: str, root2: str, exclude: list[str],
    version_highlight: str = VERSION_HIGHLIGHT_DEFAULT, **_kwargs,
) -> None:
    """Diff sources between two derivations.

    Uses nvd's package-level diffing (by pname) to match parents across
    version changes, then shows per-source detail within each changed package.
    """
    left_sources = compute_sources(root1, exclude or [])
    right_sources = compute_sources(root2, exclude or [])

    # Package-level diff using nvd's existing machinery
    left_pkg_set = _sources_to_package_set(left_sources)
    right_pkg_set = _sources_to_package_set(right_sources)

    left_pnames = set(left_pkg_set.all_pnames())
    right_pnames = set(right_pkg_set.all_pnames())
    pnames_in_both = left_pnames & right_pnames

    version_changed: list[str] = []
    for pname in pnames_in_both:
        if left_pkg_set.get_pname_versions(pname) != right_pkg_set.get_pname_versions(pname):
            version_changed.append(pname)

    added_pnames = sorted(right_pnames - left_pnames)
    removed_pnames = sorted(left_pnames - right_pnames)

    # Group sources by parent pname for per-source detail
    def group_by_parent_pname(sources: list[SourceEntry]) -> dict[str, dict[str, SourceEntry]]:
        groups: dict[str, dict[str, SourceEntry]] = {}
        for s in sources:
            groups.setdefault(s.parent_pname, {})[s.name] = s
        return groups

    left_groups = group_by_parent_pname(left_sources)
    right_groups = group_by_parent_pname(right_sources)

    # Build a dummy selected set (no selection tracking for sources)
    no_selection = PackageSetPair(None, None)

    print(f"<<< {root1}")
    print(f">>> {root2}")

    any_changes = False

    # Version changes — with per-source detail
    if version_changed:
        any_changes = True
        print(f"\n{sgr(SGR_BOLD)}Version changes:{sgr(SGR_RESET)}")
        print_packages(
            pnames=version_changed,
            selected_sets=no_selection,
            left_package_set=left_pkg_set,
            right_package_set=right_pkg_set,
            sort_comparator=DEFAULT_SORT,
            version_highlight=version_highlight,
        )

        # Per-source detail for each changed package
        for pname in sorted(version_changed):
            left_srcs = left_groups.get(pname, {})
            right_srcs = right_groups.get(pname, {})
            all_names = sorted(set(left_srcs) | set(right_srcs))

            details: list[str] = []
            for name in all_names:
                ls = left_srcs.get(name)
                rs = right_srcs.get(name)
                if ls and not rs:
                    details.append(f"    {sgr(SGR_FG + SGR_RED)}-{sgr(SGR_RESET)} {name}")
                elif rs and not ls:
                    details.append(f"    {sgr(SGR_FG + SGR_GREEN)}+{sgr(SGR_RESET)} {name}")
                elif ls.path != rs.path:
                    details.append(f"    {sgr(SGR_FG + SGR_CYAN)}~{sgr(SGR_RESET)} {name}")

            if details:
                print(f"  {sgr(SGR_BOLD)}{pname}:{sgr(SGR_RESET)}")
                for d in details:
                    print(d)

    # Added packages
    if added_pnames:
        any_changes = True
        print(f"\n{sgr(SGR_BOLD)}Added packages:{sgr(SGR_RESET)}")
        print_packages(
            pnames=added_pnames,
            selected_sets=no_selection,
            left_package_set=right_pkg_set,
            fixed_install_state=INST_ADDED,
            sort_comparator=DEFAULT_SORT,
            version_highlight=version_highlight,
        )

    # Removed packages
    if removed_pnames:
        any_changes = True
        print(f"\n{sgr(SGR_BOLD)}Removed packages:{sgr(SGR_RESET)}")
        print_packages(
            pnames=removed_pnames,
            selected_sets=no_selection,
            left_package_set=left_pkg_set,
            fixed_install_state=INST_REMOVED,
            sort_comparator=DEFAULT_SORT,
            version_highlight=version_highlight,
        )

    if not any_changes:
        print("No source changes.")

    print(f"\nSources: {len(left_sources)} -> {len(right_sources)}.")

def run_sources_collect(root: str, exclude: list[str], output: str, **_kwargs) -> None:
    """Create a symlink directory tree of sources."""
    sources = compute_sources(root, exclude or [])
    out = Path(output)
    out.mkdir(parents=True, exist_ok=False)
    for s in sources:
        parent_dir = out / s.parent
        parent_dir.mkdir(parents=True, exist_ok=True)
        link = parent_dir / s.name
        if link.exists() or link.is_symlink():
            print(f"WARNING: {link} already exists, skipping", file=sys.stderr)
            continue
        link.symlink_to(s.output_path)

def run_sources(action: str, **kwargs) -> None:
    """Dispatch sources subcommands."""
    {
        "list": run_sources_list,
        "diff": run_sources_diff,
        "collect": run_sources_collect,
    }[action](**kwargs)

