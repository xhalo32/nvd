def sgr(*args):
    assert all(isinstance(arg, int) for arg in args), \
        "sgr() args must all be integers: {args!r}"
    if not USE_COLOUR:
        return ""
    return "\x1b[" + ";".join(str(arg) for arg in args) + "m"

INST_INSTALLED = "I"
INST_ADDED = "A"
INST_REMOVED = "R"
INST_UPGRADED = "U"
INST_DOWNGRADED = "D"
INST_CHANGED = "C"

SEL_SELECTED = "*"
SEL_UNSELECTED = "."
SEL_NEWLY_SELECTED = "+"
SEL_NEWLY_UNSELECTED = "-"
# There's no way to reach these selection states currently, since selected sets
# are always computed.
SEL_LEFT_ONLY_SELECTED = "L"
SEL_LEFT_ONLY_UNSELECTED = "l"
SEL_RIGHT_ONLY_SELECTED = "R"
SEL_RIGHT_ONLY_UNSELECTED = "r"
SEL_NO_SELECTED_SETS = ""

